# WorldQuant Brain Tool Configuration
# =====================================
# Copy this file to config.properties and fill in your values.
# NEVER commit config.properties to git - it contains sensitive credentials!

# WorldQuant Brain API Cookie (required)
# Get this from your browser after logging into WorldQuant Brain:
# 1. Open browser DevTools (F12)
# 2. Go to Network tab
# 3. Make any request on platform.worldquantbrain.com
# 4. Copy the Cookie header value
wq.cookie=YOUR_COOKIE_HERE

# Email Configuration (for notifications)
# For Gmail, use an App Password: https://support.google.com/accounts/answer/185833
smtp.host=smtp.gmail.com
smtp.port=587
smtp.username=your-email@gmail.com
smtp.password=your-app-password
email.recipient=recipient@example.com

# Thread Pool Configuration
# Recommended: 2-3 threads to avoid rate limiting
thread.pool.size=3

# Alpha Filter Configuration
alpha.min.correlation=0.7
alpha.min.fitness=1.3

# =====================================
# Scheduler Configuration (Quartz)
# =====================================
# Use either cron expression OR interval (not both for same job)
# Cron format: seconds minutes hours day-of-month month day-of-week [year]

# Regular Alpha Job Schedule
# Option 1: Cron expression (run at 8 AM daily)
# scheduler.regular.cron=0 0 8 * * ?
# Option 2: Interval in minutes (run every 60 minutes)
# scheduler.regular.interval.minutes=60

# Super Alpha Job Schedule
# scheduler.super.cron=0 0 20 * * ?
# scheduler.super.interval.minutes=120

# Regular Alpha for Gen Super Job Schedule
# scheduler.regular_gen_super.cron=0 0 12 * * ?
# scheduler.regular_gen_super.interval.minutes=180

# =====================================
# Web Dashboard Configuration
# =====================================
web.port=8080

# Common Cron Examples:
# "0 0 8 * * ?"        - Every day at 8:00 AM
# "0 0 8,20 * * ?"     - Every day at 8:00 AM and 8:00 PM
# "0 0/30 * * * ?"     - Every 30 minutes
# "0 0 * * * ?"        - Every hour on the hour
# "0 0 8 ? * MON-FRI"  - Weekdays at 8:00 AM
# "0 0 0 1 * ?"        - First day of every month at midnight

# Environment Variable Overrides
# ================================
# You can override any config value using environment variables.
# Format: WQ_<PROPERTY_NAME_UPPERCASE_WITH_UNDERSCORES>
# Examples:
#   wq.cookie       -> WQ_COOKIE
#   smtp.host       -> WQ_SMTP_HOST
#   smtp.password   -> WQ_SMTP_PASSWORD
#   thread.pool.size -> WQ_THREAD_POOL_SIZE
